# ============================================================
# AssetSentinel — Backend Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/asset_degradation

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=supersecretkey_change_in_production

# --- ML Model Paths ---
# Absolute paths to your trained model artifacts
MODEL_PATH=/path/to/model/vae_model.pt
SCALER_PATH=/path/to/model/scaler.pkl
DATA_PATH=/path/to/dataset/degradation_test_all_cases.xlsx

# --- Application ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
